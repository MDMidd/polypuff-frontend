{
  "expo": {
    "name": "Poly-Puff",
    "slug": "poly-puff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0A1628"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.polypuff.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Poly-Puff needs microphone access for voice input and speaking practice.",
        "NSSpeechRecognitionUsageDescription": "Poly-Puff uses speech recognition to convert your spoken translations to text.",
        "NSPhotoLibraryUsageDescription": "Poly-Puff allows you to set a profile picture."
      },
      "buildNumber": "1"
    },
    "android": {
      "package": "com.polypuff.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "allowBackup": false,
      "versionCode": 6
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#1a1a2e",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#1a1a2e",
      "barStyle": "light-content"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Poly-Puff lets you set a profile picture."
        }
      ],
      "expo-localization",
      "expo-speech-recognition",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ADD8E6",
          "sounds": []
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "poly-puff-mobile",
          "organization": "mark-david-middleton"
        }
      ],
      "@react-native-google-signin/google-signin"
    ],
    "scheme": "poly-puff",
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a6e15539-755c-42d5-9e1e-be6ec55fd156"
      }
    },
    "owner": "polypuff",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a6e15539-755c-42d5-9e1e-be6ec55fd156"
    }
  }
}
